PORT=4003
NODE_ENV=development

# Auth
# IMPORTANT: Do not commit real secrets. Set a strong random value in your local .env
JWT_SECRET="CHANGE_ME_TO_A_LONG_RANDOM_SECRET"

# Admin bootstrap (set your own values)
# If set, the server ensures an admin user exists with role=admin.
ADMIN_EMAIL="admin@lostlink.local"
ADMIN_PASSWORD="CHANGE_ME"

# MongoDB connection string
DATABASE_URL="mongodb://localhost:27017/lostlink"

# Cloudinary (image uploads)
CLOUDINARY_CLOUD_NAME="CHANGE_ME"
CLOUDINARY_API_KEY="CHANGE_ME"
CLOUDINARY_API_SECRET="CHANGE_ME"
